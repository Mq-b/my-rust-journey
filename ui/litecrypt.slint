import {
    Button,
    LineEdit,
    HorizontalBox,
    VerticalBox,
    TextEdit,
} from "std-widgets.slint";

export component LiteCryptWindow inherits Window {
    title: "LiteCrypt";
    icon: @image-url("../assets/LiteCrypt-icon.svg");
    min-width: 480px;
    min-height: 420px;
    preferred-width: 480px;
    preferred-height: 420px;

    in-out property <string> input-text: "";
    in-out property <string> key-input: "relia123456";
    in-out property <string> encrypted-result: "";
    in-out property <string> decrypted-result: "";
    in-out property <string> status: "请输入文本和密钥，然后加密或解密";

    callback encrypt();
    callback decrypt();
    callback save-results();
    callback import-excel();

    VerticalLayout {
        padding: 12px;
        spacing: 0px;

        Text {
            text: "LiteCrypt";
            font-size: 16px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        // ━━ 输入 ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        HorizontalLayout {
            spacing: 8px;
            alignment: stretch;
            Text {
                text: "输入";
                font-size: 11px;
                font-weight: 700;
                color: #888888;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            Rectangle {
                height: 1px;
                background: #444444;
                vertical-stretch: 0;
                y: parent.height / 2;
                horizontal-stretch: 1;
            }
        }

        Rectangle { height: 6px; }

        HorizontalLayout {
            spacing: 6px;
            Text {
                text: "文本:";
                vertical-alignment: center;
                horizontal-stretch: 0;
                min-width: 36px;
                font-weight: 700;
                font-size: 13px;
            }
            LineEdit {
                text <=> root.input-text;
                placeholder-text: "输入要加密或解密的文本...";
                horizontal-stretch: 1;
                accepted => { root.encrypt(); }
            }
        }

        Rectangle { height: 6px; }

        HorizontalLayout {
            spacing: 6px;
            Text {
                text: "密钥:";
                vertical-alignment: center;
                horizontal-stretch: 0;
                min-width: 36px;
                font-weight: 700;
                font-size: 13px;
            }
            LineEdit {
                text <=> root.key-input;
                placeholder-text: "输入密钥...";
                horizontal-stretch: 1;
                accepted => { root.encrypt(); }
            }
        }

        Rectangle { height: 10px; }

        // ━━ 操作按钮 ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        HorizontalLayout {
            spacing: 6px;
            alignment: start;
            Button {
                text: "加密";
                clicked => { root.encrypt(); }
            }
            Button {
                text: "解密";
                clicked => { root.decrypt(); }
            }
            Button {
                text: "保存结果";
                clicked => { root.save-results(); }
            }
            Button {
                text: "导入Excel";
                clicked => { root.import-excel(); }
            }
        }

        Rectangle { height: 10px; }

        // ━━ 结果 ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        HorizontalLayout {
            spacing: 8px;
            alignment: stretch;
            Text {
                text: "结果";
                font-size: 11px;
                font-weight: 700;
                color: #888888;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            Rectangle {
                height: 1px;
                background: #444444;
                vertical-stretch: 0;
                y: parent.height / 2;
                horizontal-stretch: 1;
            }
        }

        Rectangle { height: 6px; }

        VerticalLayout {
            spacing: 6px;
            horizontal-stretch: 1;
            TextEdit {
                text: root.encrypted-result;
                read-only: true;
                font-size: 13px;
                min-height: 80px;
                horizontal-stretch: 1;
            }
            TextEdit {
                text: root.decrypted-result;
                read-only: true;
                font-size: 13px;
                min-height: 80px;
                horizontal-stretch: 1;
            }
        }

        Rectangle { height: 9px; }

        // ━━ 状态栏 ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        Rectangle { height: 1px; background: #333333; }
        Rectangle { height: 4px; }
        Text {
            text: root.status;
            font-size: 11px;
            color: #888888;
            horizontal-alignment: left;
            overflow: elide;
        }
    }
}
